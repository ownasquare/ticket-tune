# Copy this file to deploy/vllm/.env and adjust local paths for your machine.
BASE_MODEL=Qwen/Qwen2.5-7B-Instruct
MODEL_REVISION=a09a35458c702b33eeacc393d103063234e8bc28
SERVED_MODEL_NAME=tickettune
# Replace <run-id> with the immutable run ID printed by training. Do not point
# Compose at latest-run.json or a mutable profile-level adapter directory.
ADAPTER_PATH=../../artifacts/qwen-7b/runs/<run-id>/adapter
HF_CACHE_PATH=./.cache/huggingface
VLLM_PORT=8000
VLLM_DTYPE=auto
MAX_MODEL_LEN=2048
MAX_LORA_RANK=64
TENSOR_PARALLEL_SIZE=1
GPU_MEMORY_UTILIZATION=0.90
VLLM_SHM_SIZE=8gb
# Offline is fail-closed by default. Set both to 0 only for a deliberate,
# pinned first download, then restore 1 before the reviewed deployment run.
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
